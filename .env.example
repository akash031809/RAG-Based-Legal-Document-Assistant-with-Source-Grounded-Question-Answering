# Backend settings
BACKEND_HOST=127.0.0.1
BACKEND_PORT=8000

# Streamlit settings
STREAMLIT_PORT=8501

# LLM Providers Configuration
# To use OpenAI, set your API key:
OPENAI_API_KEY=your-openai-api-key-here

# To use local Ollama, make sure Ollama is installed and running, then set:
OLLAMA_BASE_URL=http://localhost:11434
# Default model name in Ollama (e.g., llama3, mistral, llama3.1)
OLLAMA_MODEL=llama3

# Vector DB & Storage Paths
DATA_DIR=data
DOCUMENTS_DIR=data/documents
VECTOR_STORE_DIR=data/vector_store
